generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  resumeUrl String?
  createdAt DateTime @default(now())
}

model Project {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  tagline   String
  role      String
  industry  String
  timeline  String
  body      Json
  status    String   @default("draft")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
